---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'AI-agents die je organisatie echt werk uit handen nemen';
const description = 'clawdbotsetup ontwerpt en implementeert maatwerk AI-agents voor teams die snelheid, veiligheid en betrouwbaarheid eisen. Start vanaf €1.000 (incl. 1 agent).';
---

<BaseLayout title={title} description={description}>

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section style="background:var(--gradient-hero);position:relative;overflow:hidden;">
    <!-- Decorative background elements -->
    <div style="position:absolute;inset:0;pointer-events:none;overflow:hidden;" aria-hidden="true">
      <div style="position:absolute;top:-80px;right:-120px;width:600px;height:600px;background:radial-gradient(circle,rgba(59,130,246,0.08) 0%,transparent 70%);border-radius:50%;"></div>
      <div style="position:absolute;bottom:-100px;left:-80px;width:500px;height:500px;background:radial-gradient(circle,rgba(99,102,241,0.06) 0%,transparent 70%);border-radius:50%;"></div>
      <!-- Grid pattern overlay -->
      <div style="position:absolute;inset:0;background-image:linear-gradient(var(--color-border) 1px,transparent 1px),linear-gradient(90deg,var(--color-border) 1px,transparent 1px);background-size:64px 64px;opacity:0.35;"></div>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-20 sm:py-28" style="position:relative;">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <p class="animate-on-scroll section-badge mb-5">
            <span>✦</span> Premium · Corporate · NL-first
          </p>
          <h1 class="animate-on-scroll delay-1 text-balance font-semibold tracking-tight" style="font-size:clamp(2rem,5vw,3.5rem);line-height:1.1;color:var(--color-navy)">
            AI-agents die je organisatie<br/>
            <span class="text-gradient">echt werk uit handen nemen.</span><br/>
            Binnen dagen live.
          </h1>
          <p class="animate-on-scroll delay-2 mt-6 max-w-xl text-pretty leading-relaxed" style="font-size:1.125rem;color:var(--color-text-muted)">
            clawdbotsetup ontwerpt en implementeert maatwerk AI-agents voor teams die snelheid, veiligheid en betrouwbaarheid eisen.
            Start met één production-ready agent vanaf <span class="font-semibold" style="color:var(--color-navy)">€1.000</span>.
          </p>

          <div class="animate-on-scroll delay-3 mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class="btn-primary">
              Plan een intake (20 min)
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/pricing" class="btn-secondary">
              Bekijk pricing
            </a>
          </div>

          <ul class="animate-on-scroll delay-4 mt-10 grid gap-3 text-sm sm:grid-cols-2" style="color:var(--color-text-muted)">
            <li class="flex items-start gap-2.5">
              <span class="mt-1 flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-white text-[10px]" style="background:var(--gradient-accent)">✓</span>
              €1.000 basis = 1 agent + intake + implementatie + documentatie
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1 flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-white text-[10px]" style="background:var(--gradient-accent)">✓</span>
              Koppelingen met je tools (Google Workspace, CRM, API's)
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1 flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-white text-[10px]" style="background:var(--gradient-accent)">✓</span>
              Zakelijk: logging, toegangsbeheer, gecontroleerde uitrol
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-1 flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-white text-[10px]" style="background:var(--gradient-accent)">✓</span>
              Security-by-default met Tailscale (optioneel)
            </li>
          </ul>
        </div>

        <!-- Hero card -->
        <div class="lg:col-span-5 animate-on-scroll delay-2">
          <div class="rounded-2xl border p-6 shadow-lg" style="border-color:var(--color-border);background:rgba(255,255,255,0.85);backdrop-filter:blur(8px)">
            <div class="mb-1 flex items-center gap-2">
              <span class="h-2 w-2 rounded-full" style="background:#22c55e"></span>
              <span class="text-xs font-medium" style="color:var(--color-text-xmuted)">STARTPUNT: 1 WORKFLOW</span>
            </div>
            <h2 class="mt-2 text-lg font-semibold" style="color:var(--color-navy)">Start met één cruciale workflow</h2>
            <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted)">
              We starten met één cruciale workflow, maken 'm production-ready, en breiden daarna modulair uit.
            </p>
            <div class="mt-5 space-y-3">
              <div class="rounded-xl p-4" style="background:var(--color-surface);border:1px solid var(--color-border)">
                <p class="text-xs font-medium uppercase tracking-wide" style="color:var(--color-text-xmuted)">Typische go-live</p>
                <p class="mt-1 text-2xl font-semibold" style="color:var(--color-navy)">Enkele dagen → 2 weken</p>
                <p class="mt-1.5 text-sm" style="color:var(--color-text-muted)">Afhankelijk van integraties en toegang tot systemen.</p>
              </div>
              <div class="rounded-xl p-4" style="background:var(--color-surface);border:1px solid var(--color-border)">
                <p class="text-xs font-medium uppercase tracking-wide" style="color:var(--color-text-xmuted)">Na livegang</p>
                <p class="mt-1 text-sm" style="color:var(--color-text-muted)">
                  <span class="font-semibold" style="color:var(--color-navy)">48 uur warranty</span> +
                  <span class="font-semibold" style="color:var(--color-navy)"> 2 weken break-fix</span> (business hours).
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pain points ────────────────────────────────────────────────── -->
  <section style="background:var(--color-surface);border-top:1px solid var(--color-border-soft);border-bottom:1px solid var(--color-border-soft)">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <p class="animate-on-scroll section-badge mb-4">Het probleem</p>
      <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">Waar teams op vastlopen met "AI in de praktijk"</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {[
          { title: 'Te veel pilots, te weinig productie', body: 'Losse prompts zonder ownership, monitoring of ROI.' },
          { title: 'Handmatig werk stapelt op', body: 'Triage, follow-ups, rapportages, tickets en samenvattingen.' },
          { title: 'Integraties zijn de bottleneck', body: 'AI zonder toegang tot systemen levert weinig op.' },
          { title: 'Security & compliance zorgen', body: 'Wie kan erbij, waar gaat data heen, wat wordt gelogd?' },
        ].map((item, i) => (
          <div class={`card-hover animate-on-scroll delay-${i + 1} rounded-2xl border p-6`} style="border-color:var(--color-border);background:#fff">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl text-white text-sm" style="background:var(--gradient-accent)">⚡</div>
            <h3 class="font-semibold" style="color:var(--color-navy)">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted)">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── What we deliver ────────────────────────────────────────────── -->
  <section style="background:#fff">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <p class="animate-on-scroll section-badge mb-4">Wat je krijgt</p>
          <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">Wat we leveren<br/><span style="color:var(--color-text-muted);font-weight:400;">(production-ready, niet demo-ready)</span></h2>
          <p class="animate-on-scroll delay-2 mt-4 text-sm leading-relaxed" style="color:var(--color-text-muted)">
            <span class="font-semibold" style="color:var(--color-navy)">Pakket vanaf €1.000 (incl. 1 agent):</span> één duidelijke workflow, gebouwd, getest, gedocumenteerd en uitgerold.
          </p>
          <a href="/pricing" class="animate-on-scroll delay-3 btn-secondary mt-6 inline-flex">
            Bekijk pricing
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="lg:col-span-7">
          <ul class="grid gap-4 md:grid-cols-2">
            {[
              { title: '1 AI-agent met duidelijke scope', body: 'Eén proces / één teamflow, met acceptatiecriteria.', icon: '🤖' },
              { title: 'Integraties waar het telt', body: 'API\'s/webhooks waar mogelijk; altijd expliciet gescoped.', icon: '🔌' },
              { title: 'Rollen, rechten & logging', body: 'Zakelijke baseline: least privilege en traceability.', icon: '🔐' },
              { title: 'Handover + training', body: 'Korte docs + beheerinstructies + 30-min handover.', icon: '📋' },
            ].map((item, i) => (
              <li class={`card-hover animate-on-scroll delay-${i + 1} rounded-2xl border p-5`} style="border-color:var(--color-border);background:var(--color-surface)">
                <span class="text-2xl mb-3 block">{item.icon}</span>
                <p class="font-semibold" style="color:var(--color-navy)">{item.title}</p>
                <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted)">{item.body}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Starter agents ─────────────────────────────────────────────── -->
  <section style="background:var(--color-surface);border-top:1px solid var(--color-border-soft);border-bottom:1px solid var(--color-border-soft)">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <p class="animate-on-scroll section-badge mb-4">Starter menu</p>
      <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">Starter agents <span style="color:var(--color-text-muted);font-weight:400;">(kies er één om te beginnen)</span></h2>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {[
          { title: 'Inbox & triage agent', body: 'Categoriseert requests, maakt concept-antwoorden, zet taken klaar.', icon: '📥' },
          { title: 'Lead qualification (Telegram)', body: 'Pre-kwalificeert leads en logt naar Google Sheets of CRM.', icon: '🎯' },
          { title: 'Meeting scheduling (Google Calendar)', body: 'Intake → voorstel → bevestiging. Integratie op maat.', icon: '📅' },
          { title: 'Market/competitor research', body: 'Onderzoek, samenvattingen en updates voor sales/marketing.', icon: '🔍' },
        ].map((item, i) => (
          <div class={`card-hover animate-on-scroll delay-${i % 3 + 1} rounded-2xl border p-6`} style="border-color:var(--color-border);background:#fff">
            <span class="mb-3 block text-2xl">{item.icon}</span>
            <h3 class="font-semibold" style="color:var(--color-navy)">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted)">{item.body}</p>
          </div>
        ))}
        <div class="card-hover animate-on-scroll delay-3 rounded-2xl border p-6 md:col-span-2" style="border-color:var(--color-border);background:#fff;border-left:3px solid var(--color-blue)">
          <span class="mb-3 block text-2xl">🧠</span>
          <h3 class="font-semibold" style="color:var(--color-navy)">Internal knowledge base Q&A</h3>
          <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted)">Kleine scope inbegrepen (max 25 files / 200 pagina's). Groter = add-on.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Process / Timeline ──────────────────────────────────────────── -->
  <section style="background:#fff">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <p class="animate-on-scroll section-badge mb-4">Het proces</p>
      <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">Snel, gecontroleerd, meetbaar</h2>
      <p class="animate-on-scroll delay-2 mt-3 text-sm" style="color:var(--color-text-muted)">Van eerste gesprek tot werkende agent in productie.</p>

      <!-- Timeline grid -->
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          { num: '01', title: 'Intake', body: 'Scope, risico\'s, data-bronnen, succescriteria.', color: '#3b82f6' },
          { num: '02', title: 'Design', body: 'Agent-flow, permissions, outputs, testcases.', color: '#6366f1' },
          { num: '03', title: 'Build & integrate', body: 'Implementatie + koppelingen + logging.', color: '#8b5cf6' },
          { num: '04', title: 'Review & UAT', body: 'Testen met echte cases, edge cases.', color: '#a855f7' },
          { num: '05', title: 'Go-live', body: 'Gecontroleerde uitrol + korte training.', color: '#22c55e' },
          { num: '06', title: 'Stabilisatie', body: '48 uur warranty + 2 weken break-fix.', color: '#10b981' },
        ].map((step, i) => (
          <div class={`card-hover animate-on-scroll delay-${(i % 3) + 1} rounded-2xl border p-6`} style="border-color:var(--color-border)">
            <div class="mb-4 flex items-center gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-sm font-bold text-white" style={`background:${step.color}`}>
                {step.num}
              </span>
              <h3 class="font-semibold" style="color:var(--color-navy)">{step.title}</h3>
            </div>
            <p class="text-sm leading-relaxed" style="color:var(--color-text-muted)">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Security section ───────────────────────────────────────────── -->
  <section style="background:var(--color-surface);border-top:1px solid var(--color-border-soft);border-bottom:1px solid var(--color-border-soft)">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-6">
          <p class="animate-on-scroll section-badge mb-4">Beveiliging</p>
          <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">Security by default <span style="color:var(--color-blue)">(Tailscale)</span></h2>
          <p class="animate-on-scroll delay-2 mt-4 text-sm leading-relaxed" style="color:var(--color-text-muted)">
            Remote access kan via <span class="font-semibold" style="color:var(--color-navy)">Tailscale</span> zodat beheer en troubleshooting gebeurt via een versleuteld, identity-based netwerk-zonder open poorten.
          </p>
          <ul class="animate-on-scroll delay-3 mt-6 space-y-3 text-sm" style="color:var(--color-text-muted)">
            {[
              'Least-privilege per integratie',
              'Secrets management (geen keys in code)',
              'Logging/traceability',
              'Omgevingsscheiding waar nodig',
            ].map(item => (
              <li class="flex items-center gap-2.5">
                <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-white text-[10px]" style="background:var(--color-blue)">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <a href="/security" class="animate-on-scroll delay-4 btn-secondary mt-6 inline-flex">Meer over beveiliging →</a>
        </div>
        <div class="lg:col-span-6 animate-on-scroll delay-2">
          <div class="rounded-2xl border p-8" style="border-color:var(--color-border);background:#fff">
            <div class="mb-2 flex items-center gap-2">
              <span class="text-2xl">🛡️</span>
              <h3 class="font-semibold" style="color:var(--color-navy)">Support & warranty</h3>
            </div>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--color-text-muted)">
              <span class="font-semibold" style="color:var(--color-navy)">48 uur warranty</span> (bugs/regressies binnen scope) +
              <span class="font-semibold" style="color:var(--color-navy)"> 2 weken break-fix</span> (business hours).
            </p>
            <p class="mt-4 text-sm" style="color:var(--color-text-muted)">24/7, SLA's of incident response: op aanvraag.</p>
            <div class="mt-6 rounded-xl p-4 text-sm" style="background:var(--color-surface);border:1px solid var(--color-border)">
              <p class="font-medium" style="color:var(--color-navy)">Zakelijk, discreet, productie-gereed</p>
              <p class="mt-1" style="color:var(--color-text-muted)">Geen hobbyprojecten. Premium delivery voor teams die het serieus nemen.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="animate-on-scroll relative overflow-hidden rounded-3xl px-8 py-14 sm:px-14" style="background:var(--gradient-cta)">
        <!-- Decorative circles -->
        <div style="position:absolute;top:-80px;right:-60px;width:400px;height:400px;background:radial-gradient(circle,rgba(99,102,241,0.25) 0%,transparent 70%);border-radius:50%;pointer-events:none;" aria-hidden="true"></div>
        <div style="position:absolute;bottom:-100px;left:-40px;width:300px;height:300px;background:radial-gradient(circle,rgba(59,130,246,0.20) 0%,transparent 70%);border-radius:50%;pointer-events:none;" aria-hidden="true"></div>

        <div style="position:relative;">
          <p class="mb-4 text-sm font-medium uppercase tracking-widest" style="color:rgba(255,255,255,0.5)">Klaar om te starten?</p>
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl" style="max-width:36rem;line-height:1.15">
            Klaar om één proces te automatiseren met een production-ready agent?
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-relaxed" style="color:rgba(255,255,255,0.7)">
            Plan een korte intake. Je krijgt binnen 24-48 uur een concreet voorstel met scope, planning en vaste uitgangspunten.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-6 py-3.5 text-sm font-semibold transition-all hover:bg-blue-50 hover:shadow-lg" style="color:var(--color-navy)">
              Plan intake (20 min)
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/pricing" class="inline-flex items-center justify-center gap-2 rounded-lg border px-6 py-3.5 text-sm font-medium transition-all hover:bg-white/10" style="border-color:rgba(255,255,255,0.25);color:rgba(255,255,255,0.85)">
              Bekijk pricing
            </a>
          </div>
          <p class="mt-6 text-xs" style="color:rgba(255,255,255,0.4)">Zakelijk, discreet, en gebouwd voor productie-geen hobbyprojecten.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
