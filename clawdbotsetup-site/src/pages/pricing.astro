---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pricing';
const description = '€1.000 basispakket (incl. 1 agent) + maatwerk uitbreidingen na intake.';
---

<BaseLayout title={title} description={description}>

  <!-- ── Page header ───────────────────────────────────────────────── -->
  <section style="background:var(--gradient-hero);border-bottom:1px solid var(--color-border-soft);position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true">
      <div style="position:absolute;top:-60px;right:-80px;width:500px;height:500px;background:radial-gradient(circle,rgba(59,130,246,0.09) 0%,transparent 70%);border-radius:50%;"></div>
      <div style="position:absolute;inset:0;background-image:linear-gradient(var(--color-border) 1px,transparent 1px),linear-gradient(90deg,var(--color-border) 1px,transparent 1px);background-size:64px 64px;opacity:0.3;"></div>
    </div>
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20" style="position:relative;">
      <p class="animate-on-scroll section-badge mb-5">Transparante pricing</p>
      <h1 class="animate-on-scroll delay-1 text-4xl font-semibold tracking-tight sm:text-5xl" style="color:var(--color-navy);line-height:1.1">Pricing</h1>
      <p class="animate-on-scroll delay-2 mt-4 max-w-xl text-lg" style="color:var(--color-text-muted)">
        Simpel startpunt. Premium delivery. Volledig modulair.
      </p>
    </div>
  </section>

  <!-- ── Main pricing ───────────────────────────────────────────────── -->
  <section style="background:#fff">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-6 lg:grid-cols-3">

        <!-- Base setup card -->
        <div class="animate-on-scroll card-hover rounded-2xl border p-8 lg:col-span-2" style="border-color:var(--color-border)">
          <div class="flex items-start justify-between gap-6">
            <div>
              <span class="section-badge mb-3 inline-flex">Meest gekozen</span>
              <h2 class="text-xl font-semibold" style="color:var(--color-navy)">Base setup</h2>
              <p class="mt-2 text-sm" style="color:var(--color-text-muted)">Voor teams die één workflow production‑ready willen automatiseren.</p>
            </div>
            <div class="text-right shrink-0">
              <p class="text-xs font-medium uppercase tracking-wide" style="color:var(--color-text-xmuted)">Vanaf</p>
              <p class="text-4xl font-bold mt-1" style="color:var(--color-navy)">€1.000</p>
            </div>
          </div>

          <div class="mt-8 border-t pt-8" style="border-color:var(--color-border)">
            <p class="text-xs font-semibold uppercase tracking-wide mb-4" style="color:var(--color-text-xmuted)">Wat is inbegrepen</p>
            <ul class="grid gap-3 text-sm md:grid-cols-2" style="color:var(--color-text-muted)">
              {[
                '1 agent (starter menu of 1 workflow op maat)',
                'VPS install + basis hardening',
                'Security baseline met Tailscale (optioneel)',
                'Telegram kanaal (secure baseline)',
                'Acceptatiecriteria + testcases',
                'Handover + training (30 min)',
                'Daily backups',
                '48h warranty + 2 weken break‑fix',
              ].map(item => (
                <li class="flex items-start gap-2.5">
                  <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-white text-[10px]" style="background:var(--gradient-accent)">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-8 rounded-xl p-5 text-sm" style="background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text-muted)">
            <p class="font-medium mb-1" style="color:var(--color-navy)">Add-ons na intake</p>
            Add-ons (zoals extra agents, WhatsApp, CRM, Calendar, grotere knowledge base) prijzen we na een korte intake. Zo betaal je alleen voor wat jij echt nodig hebt.
          </div>
        </div>

        <!-- CTA card -->
        <div class="animate-on-scroll delay-2 flex flex-col rounded-2xl p-8" style="background:var(--color-navy)">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color:rgba(255,255,255,0.4)">Volgende stap</p>
            <h2 class="text-xl font-semibold text-white">Intake plannen</h2>
            <p class="mt-3 text-sm leading-relaxed" style="color:rgba(255,255,255,0.65)">Plan een intake en we maken een concreet voorstel met scope en planning. Binnen 24–48 uur reactie.</p>
          </div>

          <ul class="mt-6 space-y-2.5 text-sm" style="color:rgba(255,255,255,0.65)">
            {[
              'Intake call (20–45 min)',
              'Voorstel met scope + planning',
              'Geen scope creep garantie',
              'Premium corporate delivery',
            ].map(item => (
              <li class="flex items-center gap-2.5">
                <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-[10px]" style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.8)">✓</span>
                {item}
              </li>
            ))}
          </ul>

          <div class="mt-auto pt-8">
            <a href="/contact" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-white px-5 py-3.5 text-sm font-semibold transition-all hover:bg-blue-50" style="color:var(--color-navy)">
              Plan intake
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <p class="mt-4 text-xs text-center" style="color:rgba(255,255,255,0.35)">Premium/corporate delivery. Geen scope creep.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── What's included detail ──────────────────────────────────────── -->
  <section style="background:var(--color-surface);border-top:1px solid var(--color-border-soft);border-bottom:1px solid var(--color-border-soft)">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <p class="animate-on-scroll section-badge mb-4">Starter agents</p>
      <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">Kies je startpunt</h2>
      <p class="animate-on-scroll delay-2 mt-3 text-sm max-w-xl" style="color:var(--color-text-muted)">Kies één van onderstaande starter agents als onderdeel van je basispakket. Of beschrijf je eigen workflow na intake.</p>

      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {[
          { icon: '📥', title: 'Inbox & triage agent', body: 'Categoriseert requests, maakt concept‑antwoorden, zet taken klaar.' },
          { icon: '🎯', title: 'Lead qualification (Telegram)', body: 'Pre‑kwalificeert leads en logt naar Google Sheets of CRM.' },
          { icon: '📅', title: 'Meeting scheduling', body: 'Intake → voorstel → bevestiging. Google Calendar integratie op maat.' },
          { icon: '🔍', title: 'Market/competitor research', body: 'Onderzoek, samenvattingen en updates voor sales/marketing.' },
          { icon: '🧠', title: 'Knowledge base Q&A', body: 'Max 25 files / 200 pagina\'s inbegrepen. Groter = add‑on.' },
          { icon: '✏️', title: 'Workflow op maat', body: 'Beschrijf je eigen process in de intake. We scopen en bouwen.' },
        ].map((item, i) => (
          <div class={`card-hover animate-on-scroll delay-${(i % 3) + 1} rounded-2xl border p-6`} style="border-color:var(--color-border);background:#fff">
            <span class="mb-3 block text-2xl">{item.icon}</span>
            <h3 class="font-semibold" style="color:var(--color-navy)">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted)">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────── -->
  <section style="background:#fff">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <p class="animate-on-scroll section-badge mb-4">Veelgestelde vragen</p>
      <h2 class="animate-on-scroll delay-1 text-2xl font-semibold tracking-tight" style="color:var(--color-navy)">FAQ</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {[
          {
            q: 'Is €1.000 all‑in?',
            a: '€1.000 is het basispakket voor 1 agent met standaard implementatie. Complexe integraties scopen we vooraf transparant.',
          },
          {
            q: 'Hoe snel kunnen we live?',
            a: 'Vaak binnen enkele dagen tot 2 weken, afhankelijk van integraties en toegang tot je systemen.',
          },
          {
            q: 'Wat als we meer agents nodig hebben?',
            a: 'We bouwen modulair. Elke extra agent of integratie pricen we na intake, zodat je alleen betaalt voor wat je nodig hebt.',
          },
          {
            q: 'Werken jullie met ons bestaande systeem?',
            a: 'Ja. We koppelen via API\'s/webhooks aan Google Workspace, CRM, Telegram, en meer. Scope bepalen we vooraf.',
          },
        ].map((item, i) => (
          <div class={`card-hover animate-on-scroll delay-${(i % 2) + 1} rounded-2xl border p-6`} style="border-color:var(--color-border)">
            <h3 class="font-semibold" style="color:var(--color-navy)">{item.q}</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--color-text-muted)">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="animate-on-scroll relative overflow-hidden rounded-3xl px-8 py-14 sm:px-14" style="background:var(--gradient-cta)">
        <div style="position:absolute;top:-80px;right:-60px;width:400px;height:400px;background:radial-gradient(circle,rgba(99,102,241,0.25) 0%,transparent 70%);border-radius:50%;pointer-events:none;" aria-hidden="true"></div>
        <div style="position:relative;">
          <h2 class="text-2xl font-semibold text-white sm:text-3xl" style="max-width:30rem;">Klaar om te starten? Plan een intake.</h2>
          <p class="mt-3 max-w-xl text-sm leading-relaxed" style="color:rgba(255,255,255,0.7)">We stellen je voorstel op met scope, planning en vaste uitgangspunten. Binnen 24–48 uur.</p>
          <a href="/contact" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3.5 text-sm font-semibold transition-all hover:bg-blue-50" style="color:var(--color-navy)">
            Plan intake
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
