---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pricing';
const description = '€1.000 basispakket (incl. 1 agent) + maatwerk uitbreidingen na intake.';
---

<BaseLayout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-semibold tracking-tight">Pricing</h1>
    <p class="mt-4 max-w-2xl text-slate-700">
      Simpel startpunt. Premium delivery. Volledig modulair.
    </p>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 p-8 lg:col-span-2">
        <div class="flex items-start justify-between gap-6">
          <div>
            <h2 class="text-xl font-semibold">Base setup</h2>
            <p class="mt-2 text-sm text-slate-700">Voor teams die één workflow production‑ready willen automatiseren.</p>
          </div>
          <div class="text-right">
            <p class="text-sm text-slate-500">Vanaf</p>
            <p class="text-3xl font-semibold">€1.000</p>
          </div>
        </div>

        <ul class="mt-8 grid gap-3 text-sm text-slate-700 md:grid-cols-2">
          <li>• 1 agent (kies uit ons starter menu of 1 workflow op maat)</li>
          <li>• VPS install + basis hardening (stack‑dependent)</li>
          <li>• Security baseline met Tailscale (optioneel, aanbevolen)</li>
          <li>• Telegram kanaal (secure baseline)</li>
          <li>• Acceptatiecriteria + testcases</li>
          <li>• Handover + training (30 min)</li>
          <li>• Daily backups</li>
          <li>• 48h warranty + 2 weken break‑fix (business hours)</li>
        </ul>

        <div class="mt-8 rounded-xl bg-slate-50 p-5 text-sm text-slate-700">
          Add-ons (zoals extra agents, WhatsApp, CRM, Calendar, grotere knowledge base) prijzen we na een korte intake.
          Zo betaal je alleen voor wat jij echt nodig hebt.
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
        <h2 class="text-xl font-semibold">Next step</h2>
        <p class="mt-2 text-sm text-slate-700">Plan een intake en we maken een concreet voorstel met scope en planning.</p>
        <a href="/contact" class="mt-6 inline-block w-full rounded-md bg-slate-900 px-5 py-3 text-center text-sm font-medium text-white hover:bg-slate-800">Contact</a>
        <p class="mt-4 text-xs text-slate-600">Premium/corporate delivery. Geen scope creep.</p>
      </div>
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold tracking-tight">FAQ</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 p-6">
          <h3 class="font-semibold">Is €1.000 all‑in?</h3>
          <p class="mt-2 text-sm text-slate-700">€1.000 is het basispakket voor 1 agent met standaard implementatie. Complexe integraties scopen we vooraf.</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-6">
          <h3 class="font-semibold">Hoe snel kunnen we live?</h3>
          <p class="mt-2 text-sm text-slate-700">Vaak binnen enkele dagen tot 2 weken, afhankelijk van integraties en toegang.</p>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
